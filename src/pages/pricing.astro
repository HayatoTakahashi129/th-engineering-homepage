---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import SectionTitle from "../components/SectionTitle.astro";
import CTA from "../components/CTA.astro";
---

<BaseLayout
  title="ご契約形態・費用について"
  description="THエンジニアリングの契約形態と費用について。技術パートナー契約、プロジェクト単位契約、スポット技術レビューに対応。"
>
  <section class="py-16 md:py-20">
    <Container>
      <SectionTitle title="ご契約形態・費用について" />

      <div class="max-w-3xl space-y-4 text-base leading-relaxed text-subtext md:text-lg">
        <p>
          費用はプロジェクト規模および責任範囲に応じて個別にお見積りいたします。
        </p>
        <p>
          当社は単なる工数提供ではなく、技術的判断およびリスクマネジメントを含む価値提供を前提としております。
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <div class="rounded-lg border border-gray-200 p-6 transition hover:shadow-sm">
          <h3 class="text-lg font-semibold text-text">技術パートナー契約</h3>
          <p class="mt-1 text-xs text-subtext">準委任</p>
          <p class="mt-3 text-sm leading-relaxed text-subtext">
            中長期的にプロジェクトに参画し、設計・開発・技術判断を担います。
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 p-6 transition hover:shadow-sm">
          <h3 class="text-lg font-semibold text-text">プロジェクト単位契約</h3>
          <p class="mt-3 text-sm leading-relaxed text-subtext">
            特定のプロジェクトやフェーズに限定した支援を提供します。
          </p>
        </div>
        <div class="rounded-lg border border-gray-200 p-6 transition hover:shadow-sm">
          <h3 class="text-lg font-semibold text-text">スポット技術レビュー</h3>
          <p class="mt-3 text-sm leading-relaxed text-subtext">
            アーキテクチャレビュー、コードレビューなどをスポットで実施します。
          </p>
        </div>
      </div>
    </Container>
  </section>

  <CTA title="まずは相談する" description="費用やスコープについて、お気軽にお問い合わせください。" />
</BaseLayout>
