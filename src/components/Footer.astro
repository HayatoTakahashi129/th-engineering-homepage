---
import Container from "./Container.astro";
import { navLinks } from "../data/nav";
import { site } from "../data/site";
---

<footer class="border-t border-gray-200 bg-white py-12">
  <Container>
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <div>
        <p class="text-lg font-semibold tracking-tight text-primary">
          TH Engineering
        </p>
        <p class="mt-1 text-sm text-subtext">{site.legalName}</p>
      </div>

      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="フッターナビゲーション">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm text-subtext transition hover:text-text"
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="mt-8 border-t border-gray-100 pt-6">
      <p class="text-xs text-subtext">
        &copy; {new Date().getFullYear()} {site.legalName}. All rights reserved.
      </p>
    </div>
  </Container>
</footer>
