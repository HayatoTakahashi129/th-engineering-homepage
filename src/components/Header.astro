---
import Container from "./Container.astro";
import { navLinks } from "../data/nav";
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur-sm">
  <Container class="flex h-16 items-center justify-between">
    <a href="/">
      <img src="/logo.svg" alt="TH Engineering" class="h-10" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-6 md:flex" aria-label="メインナビゲーション">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-subtext transition hover:text-text"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button
      type="button"
      class="flex items-center justify-center md:hidden"
      aria-label="メニューを開く"
      id="menu-toggle"
    >
      <svg class="h-6 w-6 text-text" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </Container>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-gray-200 bg-white md:hidden"
    aria-label="モバイルナビゲーション"
  >
    <Container class="flex flex-col gap-4 py-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-subtext transition hover:text-text"
        >
          {link.label}
        </a>
      ))}
    </Container>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
