---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-12">
  <h2 class="text-2xl font-semibold tracking-tight text-text md:text-3xl">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-3 text-base text-subtext md:text-lg">{subtitle}</p>
  )}
</div>
