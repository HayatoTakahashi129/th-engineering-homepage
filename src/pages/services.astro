---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import SectionTitle from "../components/SectionTitle.astro";
import CTA from "../components/CTA.astro";
import { services } from "../data/services";
---

<BaseLayout
  title="提供サービス"
  description="技術戦略・アーキテクチャ設計、エンタープライズ開発推進、AI活用型開発プロセス。THエンジニアリングの提供サービス。"
>
  <section class="py-16 md:py-20">
    <Container>
      <SectionTitle
        title="提供サービス"
        subtitle="単なる工数提供ではなく、技術的判断に責任を持つ。"
      />

      <div class="space-y-12">
        {services.map((s, i) => (
          <div class="rounded-lg border border-gray-200 p-6 md:p-8">
            <div class="flex items-start gap-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-semibold text-white">
                {i + 1}
              </span>
              <div>
                <h3 class="text-xl font-semibold text-text">{s.title}</h3>
                <p class="mt-2 text-base leading-relaxed text-subtext">
                  {s.description}
                </p>
                <ul class="mt-4 space-y-1">
                  {s.bullets.map((b) => (
                    <li class="flex items-center gap-2 text-sm text-subtext">
                      <span class="h-1 w-1 shrink-0 rounded-full bg-accent" />
                      {b}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <CTA title="まずは相談する" description="プロジェクトの規模や段階を問わず、お気軽にご相談ください。" />
</BaseLayout>
